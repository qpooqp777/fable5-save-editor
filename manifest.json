{
  "manifest_version": 3,
  "name": "Fable 5 Save Editor",
  "version": "2.0.0",
  "description": "Fable 5 存檔編輯器 - 修改、儲存、載入、查詢、排序遊戲存檔資料",
  "permissions": ["storage"],
  "host_permissions": [
    "*://shines871.github.io/*",
    "*://*.shines871.github.io/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {"16":"icons/icon16.png","48":"icons/icon48.png","128":"icons/icon128.png"}
  },
  "icons": {"16":"icons/icon16.png","48":"icons/icon48.png","128":"icons/icon128.png"}
}
